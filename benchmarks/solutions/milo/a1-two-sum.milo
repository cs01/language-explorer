fn twoSum(nums: &Vec<i32>, target: i32): (i32, i32) {
    var seen: HashMap<i32, i32> = HashMap.new()
    for i, n in nums {
        let complement = target - n
        match seen.get(complement) {
            Some(j) => return (j, i)
            None => seen.insert(n, i)
        }
    }
    return (-1, -1)
}
