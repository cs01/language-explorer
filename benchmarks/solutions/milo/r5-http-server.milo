from "std/http" import { Router, Context, Response, serveRouter }

fn main(): i32 {
    var router = Router.new()
    router.get("/hello", (ctx: &mut Context): Response => {
        var name = ctx.query("name")
        if name.len == 0 { name = "World" }
        return Response.Json($"\{\"greeting\": \"Hello, {name}!\"}")
    })

    let result = serveRouter(8080, router)
    if let Result.Err(msg) = result {
        print($"error: {msg}")
        return 1
    }
    return 0
}
